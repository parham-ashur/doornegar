# Doornegar backend — environment variables
#
# Copy this file to `.env` for local dev, or paste these into your
# hosting provider (Railway, OVH, Fly.io…) as environment variables.
#
# [REQUIRED] = app won't start or key features break without it.
# Everything else is optional and only needed if you use that feature.

# ──────────────────────────────────────────────────────────────
# Core app
# ──────────────────────────────────────────────────────────────
ENVIRONMENT=production          # or "development"
DEBUG=false
PORT=8000

# [REQUIRED] Secret for JWT / session signing. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# [REQUIRED] Protects /api/v1/admin/* endpoints. Long random string.
# Used by the dashboard's "Admin Token" field.
ADMIN_TOKEN=

# Comma-separated frontend origins allowed to call the API
CORS_ORIGINS=https://frontend-tau-six-36.vercel.app,http://localhost:3000

# ──────────────────────────────────────────────────────────────
# Database (PostgreSQL + pgvector)
# ──────────────────────────────────────────────────────────────
# [REQUIRED] Neon / Supabase / self-hosted Postgres.
# Both postgresql:// and postgres:// work — the app auto-converts to asyncpg
# and strips sslmode/channel_binding params Neon adds.
DATABASE_URL=postgresql://user:password@host:5432/doornegar

# ──────────────────────────────────────────────────────────────
# Redis (rate-limiting, optional Celery broker)
# ──────────────────────────────────────────────────────────────
# Upstash, Railway Redis, or local. The maintenance cron does NOT need
# Redis — only the web service (for rate-limit state) and Celery workers.
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────────────────────
# LLM API keys
# ──────────────────────────────────────────────────────────────
# At least ONE of these is required for:
#   - Farsi title translation (backfill step in auto_maintenance.py)
#   - Bias scoring
#   - Story summary generation
# Without any key, those maintenance steps log a warning and skip.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
BIAS_SCORING_MODEL=claude-haiku-4-5-20251001

# ──────────────────────────────────────────────────────────────
# Cloudflare R2 (image storage, S3-compatible)
# ──────────────────────────────────────────────────────────────
# Required for the image download + serving pipeline. Skip only if
# you don't care about preserving story thumbnails.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=doornegar-images
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ──────────────────────────────────────────────────────────────
# Telegram (MTProto, for channel ingestion)
# ──────────────────────────────────────────────────────────────
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_CHANNEL_USERNAME=
TELEGRAM_FETCH_INTERVAL_MINUTES=30

# ──────────────────────────────────────────────────────────────
# Ingestion / clustering tunables (safe defaults)
# ──────────────────────────────────────────────────────────────
INGESTION_INTERVAL_MINUTES=15
INGESTION_TIMEOUT_SECONDS=30
MAX_ARTICLES_PER_FEED=50
CLUSTERING_SIMILARITY_THRESHOLD=0.45
STORY_MERGE_THRESHOLD=0.55

# ──────────────────────────────────────────────────────────────
# Social integrations (optional — only set if you use them)
# ──────────────────────────────────────────────────────────────
# Twitter / X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Instagram (Meta Business API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Bluesky
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=
